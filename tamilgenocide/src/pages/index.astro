---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tamil Eelam Genocide — Documentation Archive</title>
  <meta name="description" content="Documenting the systematic destruction of the Tamil people in Sri Lanka.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
<div class="dashboard">

  <!-- ═══ LEFT SIDEBAR ═══════════════════════════════ -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-head">
      <div class="sidebar-label">Documentation Archive</div>
      <div class="sidebar-title">Tamil <em>Eelam</em> Genocide</div>
      <div class="sidebar-sub">Preserving evidence for accountability</div>
    </div>

    <div class="sidebar-tabs" id="sidebarTabs">
      <div class="sidebar-tab active" data-tab="incidents">Incidents</div>
      <div class="sidebar-tab" data-tab="timeline">Timeline</div>
      <div class="sidebar-tab" data-tab="memorial">Memorial</div>
      <div class="sidebar-tab" data-tab="legal">Legal</div>
    </div>

    <div class="sidebar-list" id="sidebarList"></div>

    <div class="sidebar-foot">
      <p>Thamizhi Project</p>
    </div>
  </aside>

  <!-- ═══ RIGHT PANEL ════════════════════════════════ -->
  <main class="panel" id="panel">
    <div class="panel-topbar">
      <div class="panel-topbar-title">Archive Dashboard</div>
      <div class="panel-topbar-actions">
        <div class="dropdown">
          <button onclick="document.querySelector('.dropdown-menu').classList.toggle('show')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
            Options
          </button>
          <div class="dropdown-menu">
            <div class="dropdown-item" onclick="generateCard('twitter')">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Generate Twitter Card
            </div>
            <div class="dropdown-item" onclick="generateCard('whatsapp')">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Generate WhatsApp Card
            </div>
            <div class="dropdown-divider"></div>
            <div class="dropdown-item" onclick="downloadCard()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
              Download Image
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="panel-body">
      <div class="panel-inner" id="panelContent"></div>
    </div>
  </main>
</div>

<!-- ═══ CARD MODAL ════════════════════════════════ -->
<div class="modal-overlay" id="cardModal" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="card-preview">
      <canvas id="cardCanvas" width="1080" height="1080"></canvas>
    </div>
    <div class="card-actions">
      <button class="btn-download" onclick="downloadCard()">Download</button>
      <button class="btn-twitter" onclick="shareTwitter()">Post to X</button>
      <button class="btn-whatsapp" onclick="shareWhatsApp()">WhatsApp</button>
    </div>
  </div>
</div>

<script src="../scripts/app.ts"></script>
</body>
</html>
