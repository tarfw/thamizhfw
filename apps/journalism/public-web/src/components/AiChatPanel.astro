---
export interface Props {
  isOpen?: boolean;
}
---

<aside
  id="ai-chat-panel"
  class="w-[320px] shrink-0 border-l bg-background flex flex-col h-full relative"
  aria-label="AI Chat assistant"
>
  <!-- Chat header -->
  <div class="flex items-center justify-between px-4 h-12 border-b shrink-0">
    <div class="flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-md bg-primary/10 flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
        </svg>
      </div>
      <div>
        <span class="text-sm font-medium text-foreground">AI Assistant</span>
        <span class="text-[10px] text-muted-foreground block leading-tight">Ask about articles</span>
      </div>
    </div>
    <button
      id="chat-toggle"
      class="w-7 h-7 rounded-md flex items-center justify-center text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors"
      aria-label="Close chat panel"
      title="Close chat panel"
      type="button"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Chat messages (empty — populated by JS) -->
  <div id="chat-messages" class="flex-1 overflow-y-auto px-4 py-4 space-y-4">
  </div>

  <!-- Chat input -->
  <div class="border-t p-3 shrink-0">
    <form id="chat-form" class="flex items-end gap-2">
      <div class="flex-1 relative">
        <input
          id="chat-input"
          type="text"
          placeholder="Ask about articles, topics..."
          class="w-full h-9 px-3 pr-8 text-sm rounded-md border bg-muted/50 text-foreground placeholder:text-muted-foreground/60 focus:outline-none focus:ring-1 focus:ring-ring focus:bg-background transition-colors"
          disabled
        />
        <span class="absolute right-2.5 bottom-1/2 translate-y-1/2 text-[9px] text-muted-foreground/40 font-mono">↵</span>
      </div>
      <button
        type="submit"
        class="h-9 px-3 rounded-md bg-foreground text-background text-sm font-medium hover:bg-foreground/90 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
        disabled
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
        </svg>
        <span class="sr-only">Send</span>
      </button>
    </form>
  </div>
</aside>
