---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getStorage } from '@tamilfw/core';
import type { Article } from '@tamilfw/core/journalism';

let articles: Article[] = [];
try {
  const storage = getStorage();
  const result = await storage.listArticles({
    limit: 12,
    offset: 0,
    status: 'published',
    sortBy: 'publishedAt',
    sortOrder: 'desc',
  });
  articles = result.articles;
} catch (err) {
  articles = [];
}
---
<BaseLayout
  title="Decentralized Journalism for Tamil Nadu"
  description="Investigative journalism, transparent sources, and the people who hold power accountable. Powered by Turso + open data."
>
  <section class="py-12 border-b border-gray-800">
    <div class="max-w-3xl">
      <p class="text-[#00D4AA] font-mono text-xs tracking-widest mb-4">INVESTIGATIVE • TRANSPARENT • DECENTRALIZED</p>
      <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
        Journalism that<br/>
        <span class="text-[#00D4AA]">cannot be erased.</span>
      </h1>
      <p class="text-xl text-gray-400 leading-relaxed">
        Thamizhi is a decentralized journalism platform for Tamil Nadu. Every story, source, and connection is stored in open data — no central authority can delete the record.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-white">Latest Investigations</h2>
      <a href="/articles" class="text-[#00D4AA] text-sm font-mono hover:underline">VIEW ALL →</a>
    </div>

    {articles.length === 0 ? (
      <div class="border border-gray-800 rounded-lg p-12 text-center">
        <p class="text-gray-500 text-sm">No articles yet.</p>
        <p class="text-gray-600 text-xs font-mono mt-2">Run db:seed to populate with sample data</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <a
            href={`/articles/${article.slug}`}
            class="block border border-gray-800 rounded-lg p-6 hover:border-[#00D4AA] transition group"
          >
            <div class="flex items-center gap-2 mb-3 text-xs">
              {article.category && (
                <span class="px-2 py-1 bg-blue-900/30 text-blue-300 rounded font-mono uppercase">
                  {article.category}
                </span>
              )}
              <span class="text-gray-500 font-mono">
                {article.publishedAt ? new Date(article.publishedAt).toLocaleDateString() : 'draft'}
              </span>
            </div>
            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-[#00D4AA] transition">
              {article.title}
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed line-clamp-3">{article.excerpt}</p>
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="py-12 border-t border-gray-800">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-4xl font-bold text-[#00D4AA] font-mono">{articles.length}</div>
        <div class="text-gray-500 text-sm mt-2 font-mono uppercase tracking-wider">Articles</div>
      </div>
      <div>
        <div class="text-4xl font-bold text-[#00D4AA] font-mono">0</div>
        <div class="text-gray-500 text-sm mt-2 font-mono uppercase tracking-wider">Entities Tracked</div>
      </div>
      <div>
        <div class="text-4xl font-bold text-[#00D4AA] font-mono">100%</div>
        <div class="text-gray-500 text-sm mt-2 font-mono uppercase tracking-wider">Open Data</div>
      </div>
    </div>
  </section>
</BaseLayout>
