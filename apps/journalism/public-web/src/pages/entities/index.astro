---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStorage } from '@tamilfw/core';
import type { Entity } from '@tamilfw/core/journalism';

let entities: Entity[] = [];
try {
  const storage = getStorage();
  const result = await storage.listEntities({ limit: 200, offset: 0 });
  entities = result.entities;
} catch (err) {
  entities = [];
}

const colorMap: Record<string, string> = {
  person: '#3B82F6',
  organization: '#8B5CF6',
  location: '#10B981',
  event: '#F59E0B',
  document: '#EC4899',
};
---
<BaseLayout
  title="Entities"
  description="People, organizations, locations, and events tracked by Thamizhi."
>
  <header class="mb-12">
    <h1 class="text-4xl font-bold text-white mb-4">Entities</h1>
    <p class="text-gray-400">{entities.length} tracked entities across the network</p>
  </header>

  {entities.length === 0 ? (
    <div class="border border-gray-800 rounded-lg p-12 text-center">
      <p class="text-gray-500">No entities yet.</p>
    </div>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {entities.map((entity) => (
        <a
          href={`/entities/${entity.id}`}
          class="block border border-gray-800 rounded-lg p-4 hover:border-[#00D4AA] transition"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center text-lg font-bold"
              style={`background-color: ${colorMap[entity.type] || '#6B7280'}30; color: ${colorMap[entity.type] || '#9CA3AF'}; border: 2px solid ${colorMap[entity.type] || '#6B7280'}`}
            >
              {entity.name.charAt(0).toUpperCase()}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-white font-semibold truncate">{entity.name}</div>
              <div class="text-xs text-gray-500 font-mono uppercase">{entity.type}</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
