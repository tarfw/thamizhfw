---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStorage } from '@tamilfw/core';
import type { Entity, Article, Connection } from '@tamilfw/core/journalism';

export async function getStaticPaths() {
  let entities: Entity[] = [];
  try {
    const storage = getStorage();
    const result = await storage.listEntities({ limit: 1000, offset: 0 });
    entities = result.entities;
  } catch (err) {
    entities = [];
  }
  return entities.map((entity) => ({
    params: { id: entity.id },
    props: { entity },
  }));
}

const { entity } = Astro.props as { entity: Entity };

let articles: Article[] = [];
let connections: Connection[] = [];
try {
  const storage = getStorage();
  articles = await storage.getEntityArticles(entity.id);
  connections = await storage.getEntityConnections(entity.id, 1);
} catch (err) {
  articles = [];
  connections = [];
}

const colorMap: Record<string, string> = {
  person: '#3B82F6',
  organization: '#8B5CF6',
  location: '#10B981',
  event: '#F59E0B',
  document: '#EC4899',
};
const entityColor = colorMap[entity.type] || '#6B7280';
---
<BaseLayout
  title={entity.name}
  description={entity.description || `${entity.type}: ${entity.name}`}
>
  <article class="max-w-3xl mx-auto">
    <header class="mb-12 pb-8 border-b border-gray-800 text-center">
      <div
        class="w-24 h-24 rounded-full flex items-center justify-center text-4xl font-bold mx-auto mb-4"
        style={`background-color: ${entityColor}30; color: ${entityColor}; border: 3px solid ${entityColor}`}
      >
        {entity.name.charAt(0).toUpperCase()}
      </div>
      <div class="inline-block px-3 py-1 rounded text-xs font-mono uppercase mb-3" style={`background-color: ${entityColor}20; color: ${entityColor}`}>
        {entity.type}
      </div>
      <h1 class="text-4xl font-bold text-white mb-2">{entity.name}</h1>
      {entity.aliases && entity.aliases.length > 0 && (
        <p class="text-gray-500 text-sm font-mono">aka {entity.aliases.join(', ')}</p>
      )}
    </header>

    {entity.description && (
      <section class="mb-12">
        <h2 class="text-sm font-mono uppercase tracking-wider text-gray-500 mb-4">Description</h2>
        <p class="text-gray-300 text-lg leading-relaxed">{entity.description}</p>
      </section>
    )}

    {connections.length > 0 && (
      <section class="mb-12">
        <h2 class="text-sm font-mono uppercase tracking-wider text-gray-500 mb-4">
          Connections ({connections.length})
        </h2>
        <div class="space-y-2">
          {connections.slice(0, 20).map((conn) => (
            <div class="flex items-center gap-3 p-3 border border-gray-800 rounded">
              <span class="text-gray-500 text-sm font-mono">{conn.relationship}</span>
              <span class="text-gray-600">→</span>
              <a
                href={`/entities/${conn.sourceId === entity.id ? conn.targetId : conn.sourceId}`}
                class="text-[#00D4AA] hover:underline text-sm"
              >
                View connected entity
              </a>
            </div>
          ))}
        </div>
      </section>
    )}

    {articles.length > 0 && (
      <section>
        <h2 class="text-sm font-mono uppercase tracking-wider text-gray-500 mb-4">
          Mentioned in {articles.length} article{articles.length !== 1 ? 's' : ''}
        </h2>
        <div class="space-y-4">
          {articles.slice(0, 10).map((article) => (
            <a
              href={`/articles/${article.slug}`}
              class="block border border-gray-800 rounded-lg p-4 hover:border-[#00D4AA] transition"
            >
              <h3 class="text-white font-semibold mb-1">{article.title}</h3>
              <p class="text-gray-400 text-sm">{article.excerpt}</p>
              <p class="text-gray-600 text-xs font-mono mt-2">
                {article.publishedAt ? new Date(article.publishedAt).toLocaleDateString() : 'draft'}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
