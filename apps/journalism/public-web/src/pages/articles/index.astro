---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStorage } from '@tamilfw/core';
import type { Article } from '@tamilfw/core/journalism';
import { formatDate, formatTimeAgo, readingTime, getWordCount, DOMAIN_INFO } from '../../lib/utils';

const category = Astro.url.searchParams.get('category') || '';

let articles: Article[] = [];
try {
  const storage = getStorage();
  const result = await storage.listArticles({
    limit: 100,
    offset: 0,
    status: 'published',
    sortBy: 'publishedAt',
    sortOrder: 'desc',
  });
  articles = result.articles;

  if (category) {
    articles = articles.filter((a) => a.category === category);
  }
} catch (err) {
  articles = [];
}
---

<BaseLayout
  title={category ? `${DOMAIN_INFO[category]?.label || category} Articles` : 'All Articles'}
  description={`Browse ${category ? DOMAIN_INFO[category]?.label || category : 'all'} articles from Thamizhi.`}
  currentCategory={category}
>
  <div class="px-6 py-6">
    <h1 class="text-xl font-bold text-foreground mb-0.5" style="font-family: Georgia, 'Times New Roman', serif;">
      <span data-i18n={category ? `cat.label.${category}` : 'ui.articles'}>{category ? DOMAIN_INFO[category]?.label || category : 'Articles'}</span>
    </h1>
    <p class="text-xs text-muted-foreground mb-4" data-article-count="{articles.length}">
      {articles.length} article{articles.length !== 1 ? 's' : ''}
    </p>

    {articles.length === 0 ? (
      <p class="text-sm text-muted-foreground py-10 text-center" data-i18n="ui.noArticlesCategory">No articles found in this category.</p>
    ) : (
      <div class="space-y-0 divide-y">
        {articles.map((article, i) => (
          <a href={`/articles/${article.slug}`} class:list={['block py-3.5 group', `fade-in fade-in-delay-${Math.min(i + 1, 5)}`]}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5 mb-0.5">
                {article.category && <span class="text-[10px] font-medium text-muted-foreground/70 uppercase tracking-wide">{article.category}</span>}
              </div>
              <h3 class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors leading-snug line-clamp-1">{article.title}</h3>
              <p class="text-xs text-muted-foreground line-clamp-1 mt-0.5">{article.excerpt}</p>
              <div class="flex items-center gap-1.5 text-[10px] text-muted-foreground/60 mt-1">
                <span data-ts={article.publishedAt}>{formatTimeAgo(article.publishedAt)}</span>
                <span>·</span>
                <span data-reading-time={getWordCount(article.body)}>{readingTime(article.body)}</span>
                <span>·</span>
                <span>{formatDate(article.publishedAt)}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
