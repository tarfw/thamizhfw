---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStorage } from '@tamilfw/core';
import type { Article } from '@tamilfw/core/journalism';
import { formatFullDate, formatISODate, readingTime, badgeVariant } from '../../lib/utils';
import { Badge } from '../../components/ui/badge';

export async function getStaticPaths() {
  let articles: Article[] = [];
  try {
    const storage = getStorage();
    const result = await storage.listArticles({ limit: 1000, offset: 0, status: 'published' });
    articles = result.articles;
  } catch (err) { articles = []; }
  return articles.map((article) => ({ params: { slug: article.slug }, props: { article } }));
}

const { article } = Astro.props as { article: Article };
---
<BaseLayout
  title={article.title}
  description={article.excerpt}
  type="article"
  publishedTime={formatISODate(article.publishedAt)}
  modifiedTime={formatISODate(article.updatedAt)}
  author={article.authorId || 'Thamizhi Editorial'}
>
  <article class="max-w-reading mx-auto px-6 py-10 md:py-12">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1.5 text-[11px] text-muted-foreground mb-6 fade-in" aria-label="Breadcrumb">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span class="text-muted-foreground/30">/</span>
      <a href="/articles" class="hover:text-foreground transition-colors">Articles</a>
      <span class="text-muted-foreground/30">/</span>
      <span class="text-foreground truncate max-w-[160px]">{article.title}</span>
    </nav>

    <!-- Article header -->
    <header class="mb-8 fade-in">
      {article.category && <Badge variant={badgeVariant(article.category)} className="mb-3">{article.category}</Badge>}
      <h1 class="text-2xl md:text-[2.2rem] font-bold text-foreground leading-[1.12] mb-3" style="font-family: 'Inter', sans-serif; letter-spacing: -0.02em;">{article.title}</h1>
      {article.excerpt && <p class="text-sm md:text-base text-muted-foreground leading-relaxed mb-5 max-w-lg">{article.excerpt}</p>}

      <!-- Author card -->
      <div class="flex items-center gap-2.5 pt-4 border-t">
        <div class="w-9 h-9 rounded-full bg-secondary flex items-center justify-center text-xs font-medium text-foreground shrink-0">{(article.authorId || 'T').charAt(0).toUpperCase()}</div>
        <div>
          <span class="text-sm font-medium text-foreground">{article.authorId || 'Thamizhi Editorial'}</span>
          <div class="flex items-center gap-1 text-xs text-muted-foreground">
            {article.publishedAt && <><time datetime={formatISODate(article.publishedAt)}>{formatFullDate(article.publishedAt)}</time><span class="text-muted-foreground/30">·</span></>}
            <span>{readingTime(article.body)}</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Article body -->
    <div class="prose-journal fade-in fade-in-delay-1">
      {article.body.split('\n\n').map((paragraph) => (<p>{paragraph}</p>))}
    </div>

    <!-- Source -->
    {article.sourceUrl && (
      <div class="mt-8 pt-5 border-t fade-in fade-in-delay-2">
        <div class="rounded-md border bg-muted/30 p-3.5">
          <div class="flex items-start gap-2.5">
            <svg class="w-3.5 h-3.5 text-muted-foreground mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
            </svg>
            <div>
              <p class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground mb-0.5">Source</p>
              <a href={article.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-xs text-primary hover:text-primary/80 transition-colors break-all">{article.sourceUrl.replace(/^https?:\/\//, '')} →</a>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- Back -->
    <div class="mt-8 pt-5 border-t fade-in fade-in-delay-4">
      <a href="/articles" class="inline-flex items-center gap-1 text-xs text-muted-foreground hover:text-foreground transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m0 0l7 7m-7-7l7-7" /></svg>
        Back to articles
      </a>
    </div>
  </article>
</BaseLayout>
