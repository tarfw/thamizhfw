---
import '../styles/global.css';
import CategoryPanel from '../components/CategoryPanel.astro';
import AiChatPanel from '../components/AiChatPanel.astro';
import { TRANSLATIONS, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS } from '../lib/i18n';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  canonical?: string;
  currentCategory?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  canonical,
  currentCategory = '',
} = Astro.props;

const url = canonical || Astro.url.href;
const siteName = 'THAMIZHI';
const isArticle = type === 'article';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inter font — modern, clean, shadcn default -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta name="color-scheme" content="light dark" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && <meta property="article:author" content={author} />}

    {type === 'article' && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'NewsArticle',
        headline: title,
        description,
        image: ogImage,
        datePublished: publishedTime,
        dateModified: modifiedTime || publishedTime,
        author: author ? { '@type': 'Person', name: author } : undefined,
        publisher: {
          '@type': 'Organization',
          name: siteName,
          logo: { '@type': 'ImageObject', url: '/logo.png' },
        },
        mainEntityOfPage: url,
      })} />
    )}

    <script is:inline define:vars={{ i18nData: { translations: TRANSLATIONS, categoryLabels: CATEGORY_LABELS, categoryDescriptions: CATEGORY_DESCRIPTIONS } }}>
      window.__i18n = i18nData;
      // ── Theme initialization ────────────────────────────────
      (function() {
        const saved = localStorage.getItem('thamizhi-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();

      // ── I18n: apply translations on page load & lang toggle ──
      window.__applyTranslations = function(lang) {
        var l = lang || localStorage.getItem('thamizhi-lang') || 'en';
        var data = window.__i18n || {};
        var dict = (data.translations && data.translations[l]) || {};
        var fallback = (data.translations && data.translations.en) || {};
        var catLabels = (data.categoryLabels && data.categoryLabels[l]) || {};
        var catLabelsEn = (data.categoryLabels && data.categoryLabels.en) || {};
        var catDescs = (data.categoryDescriptions && data.categoryDescriptions[l]) || {};
        var catDescsEn = (data.categoryDescriptions && data.categoryDescriptions.en) || {};

        // data-i18n: text content
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          if (!key) return;
          var translated;
          if (key.indexOf('cat.label.') === 0) {
            var catKey = key.replace('cat.label.', '');
            translated = catLabels[catKey] || catLabelsEn[catKey];
          } else if (key.indexOf('cat.desc.') === 0) {
            var catKey2 = key.replace('cat.desc.', '');
            translated = catDescs[catKey2] || catDescsEn[catKey2];
          } else {
            translated = dict[key] || fallback[key];
          }
          if (translated) el.textContent = translated;
        });

        // data-i18n-placeholder
        document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
          var key = el.getAttribute('data-i18n-placeholder');
          if (key) {
            var translated = dict[key] || fallback[key];
            if (translated) el.placeholder = translated;
          }
        });

        // data-i18n-aria (sets both aria-label and title)
        document.querySelectorAll('[data-i18n-aria]').forEach(function(el) {
          var key = el.getAttribute('data-i18n-aria');
          if (key) {
            var translated = dict[key] || fallback[key];
            if (translated) {
              el.setAttribute('aria-label', translated);
              el.setAttribute('title', translated);
            }
          }
        });

        // data-i18n-title (sets title only)
        document.querySelectorAll('[data-i18n-title]').forEach(function(el) {
          var key = el.getAttribute('data-i18n-title');
          if (key) {
            var translated;
            if (key.indexOf('cat.desc.') === 0) {
              var catKey = key.replace('cat.desc.', '');
              translated = catDescs[catKey] || catDescsEn[catKey];
            } else {
              translated = dict[key] || fallback[key];
            }
            if (translated) el.setAttribute('title', translated);
          }
        });

        // data-ts: re-compute relative time strings
        document.querySelectorAll('[data-ts]').forEach(function(el) {
          var ts = parseInt(el.getAttribute('data-ts'), 10);
          if (!ts) return;
          var diff = Date.now() - ts;
          var seconds = Math.floor(diff / 1000);
          var translated;
          if (seconds < 60) {
            translated = (dict['ui.justNow'] || 'just now');
          } else {
            var minutes = Math.floor(seconds / 60);
            if (minutes < 60) {
              translated = (dict['ui.minutesAgo'] || '{{n}}m ago').replace('{{n}}', minutes);
            } else {
              var hours = Math.floor(minutes / 60);
              if (hours < 24) {
                translated = (dict['ui.hoursAgo'] || '{{n}}h ago').replace('{{n}}', hours);
              } else {
                var days = Math.floor(hours / 24);
                if (days < 7) {
                  translated = (dict['ui.daysAgo'] || '{{n}}d ago').replace('{{n}}', days);
                } else {
                  var weeks = Math.floor(days / 7);
                  if (weeks < 4) {
                    translated = (dict['ui.weeksAgo'] || '{{n}}w ago').replace('{{n}}', weeks);
                  } else {
                    return; // fall back to date, keep as-is
                  }
                }
              }
            }
          }
          if (translated) el.textContent = translated;
        });

        // data-reading-time: re-compute reading time
        document.querySelectorAll('[data-reading-time]').forEach(function(el) {
          var words = parseInt(el.getAttribute('data-reading-time'), 10);
          if (!words) return;
          var minutes = Math.ceil(words / 200);
          var translated = (dict['ui.readingTime'] || '{{n}} min read').replace('{{n}}', minutes);
          if (translated) el.textContent = translated;
        });

        // data-article-count: translate article count with plural forms
        document.querySelectorAll('[data-article-count]').forEach(function(el) {
          var count = parseInt(el.getAttribute('data-article-count'), 10);
          if (isNaN(count)) return;
          var key = count === 1 ? 'ui.articlesCount' : 'ui.articlesCount_plural';
          var translated = (dict[key] || fallback[key] || '{{n}} article').replace('{{n}}', count);
          if (translated) el.textContent = translated;
        });
      };

      // Apply translations on initial load
      window.__applyTranslations();
    </script>
  </head>
  <body class="overflow-hidden">
    <!-- Skip to content -->
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <!-- Reading progress bar (only on article pages) -->
    {isArticle && <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>}

    <!-- ═══ 3-COLUMN LAYOUT with Zed-style collapsible panels ═══ -->
    <div class="flex h-[calc(100vh-40px)]">
      <!-- Left: Category Panel (collapsible with transition) -->
      <div id="category-panel-wrapper" class="hidden sm:flex panel-transition" style="width: var(--panel-left-width, 240px);">
        <CategoryPanel currentCategory={currentCategory} />
      </div>

      <!-- Center: Main Content -->
      <main id="main-content" class="flex-1 min-w-0 overflow-y-auto" tabindex="-1">
        <slot />
      </main>

      <!-- Right: AI Chat Panel (collapsible with transition) -->
      <div id="ai-chat-panel-wrapper" class="hidden sm:flex panel-transition" style="width: var(--panel-right-width, 320px); overflow: hidden;">
        <AiChatPanel />
      </div>
    </div>

    <!-- Mobile overlays (slide transitions) -->
    <div id="mobile-category-overlay" class="mobile-overlay fixed inset-0 z-[60] sm:hidden">
      <div class="mobile-backdrop absolute inset-0 bg-black/40" id="mobile-category-backdrop"></div>
      <div class="mobile-panel-left absolute left-0 top-0 bottom-0 w-[260px] bg-background shadow-xl"><CategoryPanel currentCategory={currentCategory} /></div>
    </div>
    <div id="mobile-chat-overlay" class="mobile-overlay fixed inset-0 z-[60] sm:hidden">
      <div class="mobile-backdrop absolute inset-0 bg-black/40" id="mobile-chat-backdrop"></div>
      <div class="mobile-panel-right absolute right-0 top-0 bottom-0 w-[85vw] max-w-[360px] bg-background shadow-xl"><AiChatPanel /></div>
    </div>

    <button id="back-to-top" class="back-to-top" aria-label="Back to top" title="Back to top" data-i18n-aria="ui.backToTop" type="button">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" /></svg>
    </button>

    <!-- ═══ BOTTOM BAR (Zed-style footer) ═══ -->
    <footer class="h-10 fixed bottom-0 left-0 right-0 z-50 bottom-bar-mica" role="contentinfo">
      <nav class="relative h-full w-full px-4 flex items-center justify-between" aria-label="Footer navigation">
        <!-- Left: nav controls -->
        <div class="flex items-center gap-1.5">
          <!-- Mobile menu toggle (shadcn-style) -->
          <button id="mobile-menu-toggle" class="sm:hidden w-8 h-8 rounded-md flex items-center justify-center text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors" data-i18n-aria="ui.toggleMenu" aria-label="Toggle menu" type="button">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="18" x2="20" y2="18" /></svg>
          </button>

          <!-- Desktop: Left panel toggle (Cmd+B) → shadcn panel-left icon -->
          <button id="panel-toggle" class="hidden sm:inline-flex w-8 h-8 rounded-md items-center justify-center text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors" data-i18n-aria="ui.toggleSidebar" aria-label="Toggle sidebar (Cmd+B)" title="Toggle sidebar (⌘B)" type="button">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="9" y1="3" x2="9" y2="21" /></svg>
          </button>

          <!-- Logo: Five-spoked asterisk + Thamizhi -->
          <a href="/" class="flex items-center gap-2 group ml-1" aria-label="THAMIZHI home">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" class="text-foreground shrink-0 transition-transform duration-200 group-hover:scale-110 group-hover:rotate-[12deg]" aria-hidden="true">
              <line x1="12" y1="2" x2="12" y2="22" />
              <line x1="17.9" y1="3.9" x2="6.1" y2="20.1" />
              <line x1="21.5" y1="8.9" x2="2.5" y2="15.1" />
              <line x1="21.5" y1="15.1" x2="2.5" y2="8.9" />
              <line x1="17.9" y1="20.1" x2="6.1" y2="3.9" />
            </svg>
            <span class="text-foreground font-bold tracking-tight text-sm group-hover:text-muted-foreground transition-colors duration-200">Thamizhi</span>
          </a>
        </div>

        <!-- Center: tagline + download app + language chip → absolutely centered -->
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2 sm:gap-3 text-[10px] sm:text-[11px] text-muted-foreground/60">
          <span class="hidden sm:inline">decentralized open journalism</span>
          <span class="w-px h-3 bg-border/60" aria-hidden="true"></span>
          <a href="https://thamizh.app/" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex h-6 px-2 rounded items-center text-[11px] font-medium text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors">
            Download App
          </a>
          <span class="w-px h-3 bg-border/60" aria-hidden="true"></span>
          <!-- Language selection chip -->
          <div id="lang-toggle" class="lang-chip flex items-center rounded-md border border-border/60 overflow-hidden" role="radiogroup" aria-label="Switch language" title="Switch language">
            <button role="radio" aria-checked="true" id="lang-en" class="lang-chip-option px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide transition-colors">EN</button>
            <button role="radio" aria-checked="false" id="lang-ta" class="lang-chip-option px-2 py-0.5 text-[10px] font-semibold tracking-wide transition-colors">த</button>
          </div>
        </div>

        <!-- Right: controls (pushed to far right) -->
        <div class="flex items-center gap-1">
          <!-- Mobile chat toggle (shadcn message-square) -->
          <button id="mobile-chat-toggle" class="sm:hidden w-8 h-8 rounded-md flex items-center justify-center text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors" data-i18n-aria="ui.toggleChat" aria-label="Toggle AI chat" type="button">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
          </button>

          <!-- Desktop: AI Chat toggle (Cmd+J) → shadcn message-square -->
          <button id="chat-panel-toggle" class="hidden sm:inline-flex w-8 h-8 rounded-md items-center justify-center text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors" data-i18n-aria="ui.toggleChat" aria-label="Toggle AI chat (Cmd+J)" title="Toggle AI chat (⌘J)" type="button">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
          </button>

          <!-- Theme Toggle (shadcn-style, animated) -->
          <button id="theme-toggle" class="w-8 h-8 rounded-md flex items-center justify-center text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors theme-toggle-btn" data-i18n-aria="ui.toggleTheme" aria-label="Toggle dark mode" title="Toggle dark mode" type="button">
            <svg id="theme-toggle-sun" class="w-4 h-4 theme-toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
            </svg>
            <svg id="theme-toggle-moon" class="w-4 h-4 hidden theme-toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        </div>
      </nav>
    </footer>

    <script is:inline>
      // ── Language Toggle (selection chip) ──────────────────────
      (function() {
        var container = document.getElementById('lang-toggle');
        var en = document.getElementById('lang-en');
        var ta = document.getElementById('lang-ta');
        var html = document.documentElement;
        if (!container || !en || !ta) return;
        var saved = localStorage.getItem('thamizhi-lang') || 'en';
        function apply(lang) {
          html.lang = lang === 'ta' ? 'ta' : 'en';
          var active = lang === 'ta' ? ta : en;
          var inactive = lang === 'ta' ? en : ta;
          active.setAttribute('aria-checked', 'true');
          inactive.setAttribute('aria-checked', 'false');
          active.classList.add('bg-foreground', 'text-background');
          active.classList.remove('text-muted-foreground');
          inactive.classList.remove('bg-foreground', 'text-background');
          inactive.classList.add('text-muted-foreground');
          if (window.__applyTranslations) window.__applyTranslations(lang);
        }
        apply(saved);
        function toggleLang() {
          var cur = localStorage.getItem('thamizhi-lang') || 'en';
          var next = cur === 'en' ? 'ta' : 'en';
          apply(next);
          try { localStorage.setItem('thamizhi-lang', next); } catch {}
        };
        en.addEventListener('click', function(e) {
          var cur = localStorage.getItem('thamizhi-lang') || 'en';
          if (cur !== 'en') toggleLang();
        });
        ta.addEventListener('click', function(e) {
          var cur = localStorage.getItem('thamizhi-lang') || 'en';
          if (cur !== 'ta') toggleLang();
        });
      })();

      // ── Theme Toggle ──────────────────────────────────────────
      (function() {
        const html = document.documentElement;
        const toggle = document.getElementById('theme-toggle');
        const sunIcon = document.getElementById('theme-toggle-sun');
        const moonIcon = document.getElementById('theme-toggle-moon');
        if (!toggle) return;
        function setTheme(isDark) {
          if (isDark) { html.classList.add('dark'); sunIcon?.classList.remove('hidden'); moonIcon?.classList.add('hidden'); }
          else { html.classList.remove('dark'); sunIcon?.classList.add('hidden'); moonIcon?.classList.remove('hidden'); }
          // Trigger rotate animation
          const icons = toggle.querySelectorAll('.theme-toggle-icon');
          icons.forEach(icon => { icon.classList.add('rotated'); setTimeout(() => icon.classList.remove('rotated'), 350); });
        }
        setTheme(html.classList.contains('dark'));
        toggle.addEventListener('click', () => { const d = !html.classList.contains('dark'); setTheme(d); try { localStorage.setItem('thamizhi-theme', d ? 'dark' : 'light'); } catch {} });
      })();

      // ── Reading Progress ──────────────────────────────────────
      (function() {
        const bar = document.getElementById('reading-progress');
        if (!bar) return;
        function update() { const s = window.scrollY, d = document.documentElement.scrollHeight - window.innerHeight; bar.style.width = (d > 0 ? Math.min((s / d) * 100, 100) : 0) + '%'; }
        window.addEventListener('scroll', update, { passive: true }); window.addEventListener('resize', update, { passive: true }); update();
      })();

      // ── Back to Top ───────────────────────────────────────────
      (function() {
        const main = document.getElementById('main-content'), btn = document.getElementById('back-to-top');
        if (!btn || !main) return;
        main.addEventListener('scroll', () => btn.classList.toggle('visible', main.scrollTop > 500), { passive: true });
        btn.addEventListener('click', () => main.scrollTo({ top: 0, behavior: 'smooth' }));
      })();

      // ── Zed-style Panel Toggles with Keyboard Shortcuts ──────
      (function() {
        const leftWrapper = document.getElementById('category-panel-wrapper');
        const rightWrapper = document.getElementById('ai-chat-panel-wrapper');
        const panelToggle = document.getElementById('panel-toggle');
        const chatToggle = document.getElementById('chat-panel-toggle');
        if (!leftWrapper || !rightWrapper || !panelToggle || !chatToggle) return;

        const LS_LEFT = 'thamizhi-panel-left';
        const LS_RIGHT = 'thamizhi-panel-right';
        const LEFT_W = 240;
        const RIGHT_W = 320;

        // Restore state
        let leftOpen = localStorage.getItem(LS_LEFT) !== 'closed';
        let rightOpen = localStorage.getItem(LS_RIGHT) !== 'closed';

        function applyLeft() {
          leftWrapper.style.setProperty('--panel-left-width', leftOpen ? LEFT_W + 'px' : '0px');
          panelToggle.setAttribute('aria-label', leftOpen ? 'Close sidebar (⌘B)' : 'Open sidebar (⌘B)');
          panelToggle.setAttribute('title', leftOpen ? 'Close sidebar (⌘B)' : 'Open sidebar (⌘B)');
        }
        function applyRight() {
          rightWrapper.style.setProperty('--panel-right-width', rightOpen ? RIGHT_W + 'px' : '0px');
          chatToggle.setAttribute('aria-label', rightOpen ? 'Close AI chat (⌘J)' : 'Open AI chat (⌘J)');
          chatToggle.setAttribute('title', rightOpen ? 'Close AI chat (⌘J)' : 'Open AI chat (⌘J)');
        }

        applyLeft();
        applyRight();

        panelToggle.addEventListener('click', () => { leftOpen = !leftOpen; applyLeft(); try { localStorage.setItem(LS_LEFT, leftOpen ? 'open' : 'closed'); } catch {} });
        chatToggle.addEventListener('click', () => { rightOpen = !rightOpen; applyRight(); try { localStorage.setItem(LS_RIGHT, rightOpen ? 'open' : 'closed'); } catch {} });

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
          // Cmd+B or Ctrl+B to toggle left panel
          if ((e.metaKey || e.ctrlKey) && e.key === 'b') {
            e.preventDefault();
            leftOpen = !leftOpen; applyLeft(); try { localStorage.setItem(LS_LEFT, leftOpen ? 'open' : 'closed'); } catch {}
          }
          // Cmd+J or Ctrl+J to toggle right panel
          if ((e.metaKey || e.ctrlKey) && e.key === 'j') {
            e.preventDefault();
            rightOpen = !rightOpen; applyRight(); try { localStorage.setItem(LS_RIGHT, rightOpen ? 'open' : 'closed'); } catch {}
          }
        });
      })();

      // ── Mobile Menu Toggle (slide transition) ────────────────
      (function() {
        const btn = document.getElementById('mobile-menu-toggle'), overlay = document.getElementById('mobile-category-overlay'), backdrop = document.getElementById('mobile-category-backdrop');
        if (!btn || !overlay || !backdrop) return;
        btn.addEventListener('click', () => { overlay.classList.add('open'); document.body.style.overflow = 'hidden'; });
        backdrop.addEventListener('click', () => { overlay.classList.remove('open'); document.body.style.overflow = ''; });
      })();

      // ── Mobile Chat Toggle (slide transition) ────────────────
      (function() {
        const btn = document.getElementById('mobile-chat-toggle'), overlay = document.getElementById('mobile-chat-overlay'), backdrop = document.getElementById('mobile-chat-backdrop');
        if (!btn || !overlay || !backdrop) return;
        btn.addEventListener('click', () => { overlay.classList.add('open'); document.body.style.overflow = 'hidden'; });
        backdrop.addEventListener('click', () => { overlay.classList.remove('open'); document.body.style.overflow = ''; });
      })();

      // ── Swipe to close mobile panels ─────────────────────────
      (function() {
        function makeSwipeable(overlayId, panelSelector, direction) {
          const overlay = document.getElementById(overlayId);
          const panel = overlay ? overlay.querySelector(panelSelector) : null;
          if (!overlay || !panel) return;

          var startX = 0, startY = 0, currentX = 0, isDragging = false;
          var panelWidth = 0;
          const THRESHOLD = 0.3; // close if dragged >30% of panel width

          function close() {
            overlay.classList.remove('open');
            panel.style.transform = '';
            panel.style.transition = '';
            document.body.style.overflow = '';
          }

          function onStart(e) {
            // Only respond to direct touches on the panel or its backdrop
            var touch = e.touches[0];
            startX = touch.clientX;
            startY = touch.clientY;
            currentX = startX;
            isDragging = false;
            panelWidth = panel.offsetWidth;
          }

          function onMove(e) {
            var touch = e.touches[0];
            var dx = touch.clientX - startX;
            var dy = touch.clientY - startY;

            // Only initiate drag if horizontal movement is > vertical
            if (!isDragging && Math.abs(dx) < 8 && Math.abs(dy) < 8) return;
            if (!isDragging && Math.abs(dy) > Math.abs(dx)) return;

            e.preventDefault();
            isDragging = true;
            currentX = touch.clientX;

            var delta = currentX - startX;
            // For left panel: negative delta = swipe left (close direction), positive = resisted
            // For right panel: positive delta = swipe right (close direction), negative = resisted
            var translate = direction === 'left'
              ? Math.min(delta, 0)  // left panel: allow negative deltas (swipe left = close)
              : Math.max(delta, 0); // right panel: allow positive deltas (swipe right = close)

            // Add resistance — harder to drag further
            var resisted = translate * 0.4;
            panel.style.transition = 'none';
            panel.style.transform = 'translateX(' + resisted + 'px)';
          }

          function onEnd() {
            if (!isDragging) return;
            isDragging = false;

            var delta = currentX - startX;
            var absDelta = Math.abs(delta);
            var shouldClose = absDelta > panelWidth * THRESHOLD || absDelta > 60;

            if (shouldClose) {
              // Animate off-screen then hide
              var finalTranslate = direction === 'left'
                ? -panelWidth + 'px'
                : panelWidth + 'px';
              panel.style.transition = 'transform 0.2s cubic-bezier(0.4, 0, 0.2, 1)';
              panel.style.transform = 'translateX(' + finalTranslate + ')';
              setTimeout(close, 200);
            } else {
              // Snap back
              panel.style.transition = 'transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1)';
              panel.style.transform = '';
              setTimeout(function() {
                panel.style.transition = '';
              }, 300);
            }
          }

          panel.addEventListener('touchstart', onStart, { passive: true });
          panel.addEventListener('touchmove', onMove, { passive: false });
          panel.addEventListener('touchend', onEnd);
        }

        makeSwipeable('mobile-category-overlay', '.mobile-panel-left', 'left');
        makeSwipeable('mobile-chat-overlay', '.mobile-panel-right', 'right');
      })();
    </script>
  </body>
</html>
