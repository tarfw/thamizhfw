---
interface Props {
  title: string;
  value: string | number;
  subtitle?: string;
}

const { title, value, subtitle } = Astro.props;
---

<div class="text-center py-6 px-4">
  <div class="text-3xl font-bold text-[var(--text-primary)]" style="font-family: var(--font-serif);">
    {value}
  </div>
  <div class="text-xs font-semibold text-[var(--text-secondary)] mt-1.5 uppercase tracking-wider">
    {title}
  </div>
  {subtitle && (
    <div class="text-xs text-[var(--text-muted)] mt-0.5">{subtitle}</div>
  )}
</div>
