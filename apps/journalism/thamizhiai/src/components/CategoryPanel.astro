---
import { DOMAIN_INFO, CATEGORY_COLORS } from '../lib/utils';

// Map CATEGORY_COLORS values to Tailwind bg-*-500 classes
const COLOR_MAP: Record<string, string> = {
  amber: 'bg-amber-500',
  red: 'bg-red-500',
  teal: 'bg-teal-500',
  green: 'bg-green-500',
  blue: 'bg-blue-500',
  purple: 'bg-purple-500',
  rose: 'bg-rose-500',
  emerald: 'bg-emerald-500',
  orange: 'bg-orange-500',
  lime: 'bg-lime-500',
  cyan: 'bg-cyan-500',
  violet: 'bg-violet-500',
  pink: 'bg-pink-500',
};

// ── Category Groups for collapsible sections ──────────────────
const CATEGORY_GROUPS: { id: string; label: string; keys: string[] }[] = [
  {
    id: 'justice',
    label: 'Justice & Rights',
    keys: ['women-violence', 'investigation', 'crime', 'human-rights'],
  },
  {
    id: 'society',
    label: 'Society & Culture',
    keys: ['culture', 'education', 'health', 'social-welfare', 'sports'],
  },
  {
    id: 'economy',
    label: 'Economy & Environment',
    keys: ['economy', 'environment', 'agriculture', 'infrastructure'],
  },
  {
    id: 'tech',
    label: 'Technology',
    keys: ['technology'],
  },
];

export interface Props {
  currentCategory?: string;
}

const { currentCategory = '' } = Astro.props;

const allActive = !currentCategory;
const allGroups = CATEGORY_GROUPS;
// Find which group the current category belongs to
const activeGroupId = currentCategory
  ? CATEGORY_GROUPS.find((g) => g.keys.includes(currentCategory))?.id || null
  : null;
---

<aside
  id="category-panel"
  class="w-[240px] shrink-0 border-r bg-background flex flex-col h-full"
  aria-label="Category navigation"
>
  <!-- Search input -->
  <div class="shrink-0 px-2 pt-2 pb-2">
    <div class="relative">
      <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3 h-3 text-muted-foreground/35 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input
        class="category-filter-input w-full h-7 pl-7 pr-7 rounded-md bg-secondary/40 text-xs placeholder:text-muted-foreground/40 border border-transparent focus:border-border/60 focus:bg-secondary/60 focus:outline-none transition-all duration-150"
        type="text"
        data-i18n-placeholder="ui.filterCategories"
        data-i18n-aria="ui.filterCategories"
        placeholder="Filter categories..."
        autocomplete="off"
        spellcheck="false"
      />
      <button class="category-filter-clear absolute right-1 top-1/2 -translate-y-1/2 w-4 h-4 hidden items-center justify-center rounded text-muted-foreground/30 hover:text-muted-foreground hover:bg-secondary transition-colors" type="button" tabindex="-1" aria-label="Clear filter">
        <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
      </button>
    </div>
  </div>

  <!-- Scrollable nav -->
  <nav class="category-scroll flex-1 overflow-y-auto px-2 pb-3 space-y-0.5" aria-label="Categories">
    <!-- All Articles (home) -->
    <a class="category-all-link"
      href="/articles"
      data-i18n-title="ui.browseAll"
      title="Browse all articles"
      class:list={[
        'group relative flex items-center gap-2.5 px-3 py-2 rounded-md text-sm transition-all duration-150',
        allActive
          ? 'bg-secondary text-foreground font-medium'
          : 'text-muted-foreground hover:text-foreground hover:bg-secondary/50',
      ]}
    >
      {allActive && <span class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-4 bg-foreground rounded-full" aria-hidden="true" />}
      <svg class="w-3.5 h-3.5 shrink-0 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
      </svg>
      <span class="truncate" data-i18n="ui.allArticles">All Articles</span>
    </a>

    <!-- Divider -->
    <div class="my-2.5 mx-3 h-px bg-border/60" aria-hidden="true"></div>

    <!-- Collapsible category groups -->
    {allGroups.map((group) => {
      const groupActive = activeGroupId === group.id;
      const allInGroup = group.keys.map((k) => [k, DOMAIN_INFO[k]] as const);
      return (
        <div class="category-group" data-group-id={group.id}>
          <!-- Section header -->
          <div
            class={[
              'flex items-center gap-2 px-3 py-2 text-xs font-semibold uppercase tracking-wider category-group-header',
              groupActive
                ? 'text-foreground'
                : 'text-muted-foreground/50',
            ].join(' ')}
          >
            <span class="truncate">{group.label}</span>
          </div>

          <!-- Collapsible items container (state managed by JS via data-state) -->
          <div class="category-items">
            {allInGroup.map(([key, info]) => {
              const isActive = currentCategory === key;
              const colorKey = CATEGORY_COLORS[key] || 'muted';
              const catColor = COLOR_MAP[colorKey] || 'bg-muted-foreground';
              return (
                <a
                  href={`/articles?category=${key}`}
                  data-i18n-title={`cat.desc.${key}`}
                  title={info.description}
                  class:list={[
                    'group relative flex items-center gap-2.5 pl-7 pr-3 py-1.5 rounded-md text-sm transition-all duration-150',
                    isActive
                      ? 'bg-secondary text-foreground font-medium'
                      : 'text-muted-foreground hover:text-foreground hover:bg-secondary/50',
                  ]}
                >
                  {isActive && <span class="absolute left-[18px] top-1/2 -translate-y-1/2 w-0.5 h-3.5 bg-foreground rounded-full" aria-hidden="true" />}
                  <span
                    class={[
                      'w-1.5 h-1.5 rounded-full shrink-0 transition-transform duration-150 group-hover:scale-110',
                      catColor,
                      isActive ? 'ring-[1.5px] ring-offset-[2px] ring-offset-background ring-current' : '',
                    ].join(' ')}
                    aria-hidden="true"
                  />
                  <span class="truncate" data-i18n={`cat.label.${key}`}>{info.label}</span>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}

    <!-- No results message (hidden by default) -->
    <div class="category-no-results hidden px-3 py-6 text-center">
      <p class="text-xs text-muted-foreground/50" data-i18n="ui.noFilterResults">No categories match your filter.</p>
    </div>
  </nav>


</aside>

<script is:inline>
  // ── Category filter/search ───────────────────────────────────
  (function() {
    document.querySelectorAll('.category-filter-input').forEach(function(input) {
      if (input.getAttribute('data-filter-init')) return;
      input.setAttribute('data-filter-init', '1');

      var clearBtn = input.parentNode.querySelector('.category-filter-clear');

      function filter() {
        var panel = input.closest('aside');
        if (!panel) return;
        var term = input.value.toLowerCase().trim();

        var allLink = panel.querySelector('.category-all-link');
        var groups = panel.querySelectorAll('.category-group');
        var noResults = panel.querySelector('.category-no-results');
        var hasActiveFilter = term.length > 0;

        // Show/hide clear button
        if (clearBtn) {
          clearBtn.style.display = term.length > 0 ? 'flex' : 'none';
        }

        var anyVisible = false;

        // Filter "All Articles" link
        if (allLink) {
          var text = (allLink.textContent || '').toLowerCase();
          allLink.style.display = !hasActiveFilter || text.indexOf(term) !== -1 ? '' : 'none';
          if (allLink.style.display !== 'none') anyVisible = true;
        }

        // Filter each group
        groups.forEach(function(group) {
          var groupHasMatch = false;
          var items = group.querySelectorAll('.category-items a');

          items.forEach(function(item) {
            var text = (item.textContent || '').toLowerCase();
            var matches = !hasActiveFilter || text.indexOf(term) !== -1;
            item.style.display = matches ? '' : 'none';
            if (matches) groupHasMatch = true;
          });

          // Also check the group header label
          if (!groupHasMatch) {
            var headerLabel = group.querySelector('.category-group-header .truncate');
            if (headerLabel) {
              var labelText = (headerLabel.textContent || '').toLowerCase();
              if (hasActiveFilter && labelText.indexOf(term) !== -1) groupHasMatch = true;
            }
          }

          group.style.display = groupHasMatch ? '' : 'none';
          if (groupHasMatch) anyVisible = true;
        });

        // Show/hide no results
        if (noResults) {
          noResults.style.display = hasActiveFilter && !anyVisible ? 'block' : 'none';
        }
      }

      input.addEventListener('input', filter);

      // Clear on Escape
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          input.value = '';
          filter();
          input.blur();
        }
      });

      // Clear button click
      if (clearBtn) {
        clearBtn.addEventListener('click', function() {
          input.value = '';
          filter();
          input.focus();
        });
      }
    });
  })();
</script>
