{
  "name": "tamilfw",
  "private": true,
  "workspaces": [
    "apps/*",
    "web-frontends/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,astro,md}\"",
    "db:push": "turbo run db:push --filter=@tamilfw/core...",
    "db:seed": "turbo run db:seed --filter=@tamilfw/core..."
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@11.7.0"
}