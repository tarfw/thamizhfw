{
  "name": "tamilfw",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/journalism/expo-dashboard",
    "apps/journalism/public-web",
    "web-frontends/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,astro,md}\"",
    "db:push": "turbo run db:push --filter=@tamilfw/core...",
    "db:seed": "turbo run db:seed --filter=@tamilfw/core..."
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@astrojs/react": "5.0.7",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9"
  }
}
